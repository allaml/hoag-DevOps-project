# GitLab Integration Configuration
# Update these values before running terraform apply

# GitLab instance URL
gitlab_url = "https://gitlab.zayo.com"  # Change to your GitLab instance

# GitLab personal access token
# IMPORTANT: Get this token from GitLab DevOps team
# Required scopes: api, read_api, read_repository, read_user
gitlab_token = "REPLACE_WITH_YOUR_GITLAB_TOKEN"
