            "id": "3969064177",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"AllowAwsSupportActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"support:DescribeCases\",\n        \"support:CreateCase\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"AllowExpandedAIOpsAssistantPolicy\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"synthetics:GetCanaryRuns\",\n        \"route53:GetHealthCheckStatus\",\n        \"resource-explorer-2:Search\",\n        \"eks:AccessKubernetesApi\",\n        \"aidevops:ListKnowledgeItems\",\n        \"aidevops:GetKnowledgeItem\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"AllowPassRoleForCrossAccount\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:PassRole\",\n      \"Resource\": \"arn:aws:iam::*:role/DevOpsAgentCrossAccountRole\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"iam:PassedToService\": \"devopsagent.amazonaws.com\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"AllowAwsSupportActions\",\"Effect\":\"Allow\",\"Action\":[\"support:DescribeCases\",\"support:CreateCase\"],\"Resource\":\"*\"},{\"Sid\":\"AllowExpandedAIOpsAssistantPolicy\",\"Effect\":\"Allow\",\"Action\":[\"synthetics:GetCanaryRuns\",\"route53:GetHealthCheckStatus\",\"resource-explorer-2:Search\",\"eks:AccessKubernetesApi\",\"aidevops:ListKnowledgeItems\",\"aidevops:GetKnowledgeItem\"],\"Resource\":\"*\"},{\"Sid\":\"AllowPassRoleForCrossAccount\",\"Effect\":\"Allow\",\"Action\":\"iam:PassRole\",\"Resource\":\"arn:aws:iam::*:role/DevOpsAgentCrossAccountRole\",\"Condition\":{\"StringEquals\":{\"iam:PassedToService\":\"devopsagent.amazonaws.com\"}}}]}",
