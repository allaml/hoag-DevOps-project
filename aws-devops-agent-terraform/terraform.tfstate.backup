            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRole\",\n      \"Principal\": {\n        \"Service\": \"aidevops.amazonaws.com\"\n      },\n      \"Condition\": {\n        \"ArnLike\": {\n          \"aws:SourceArn\": \"arn:aws:aidevops:us-east-1:414351351247:agentspace/*\"\n        },\n        \"StringEquals\": {\n          \"aws:SourceAccount\": \"414351351247\"\n        }\n      }\n    }\n  ]\n}",
